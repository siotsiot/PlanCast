<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/scheduleTimeTextView"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:textColor="#2864FF"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="09:30" />

            <TextView
                android:id="@+id/scheduleTitleTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#111827"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="팀 프로젝트 회의" />

            <TextView
                android:id="@+id/scheduleActivityTypeTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="#EDF2FF"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="#2841A3"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="실내" />
        </LinearLayout>

        <TextView
            android:id="@+id/scheduleMemoTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="#4B5563"
            android:textSize="14sp"
            tools:text="회의 자료와 노트북 챙기기" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
